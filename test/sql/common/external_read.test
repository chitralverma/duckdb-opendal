# name: test/sql/common/external_read.test
# description: Read objects written by a different client (not opendal's writer)
# group: [common]

#
# ${OPENDAL_EXTERNAL_BASE} points at a prefix seeded at provisioning time by the
# service's init sidecar (e.g. `mc cp` for s3), i.e. objects opendal did not
# write. Only configs whose service is externally seeded set this var, so the
# file is skipped for in-process services (memory) and any service without an
# external seed. The fixtures are the shared set from `make fixtures`.

require opendal

require parquet

require-env OPENDAL_EXTERNAL_BASE

# Do not skip service (HTTP/connection) errors.
set ignore_error_messages

query II
SELECT count(*), sum(d) FROM read_parquet('${OPENDAL_EXTERNAL_BASE}/ext_seed.parquet');
----
100	9900

query II
SELECT count(*), max(id) FROM read_csv('${OPENDAL_EXTERNAL_BASE}/ext_seed.csv');
----
50	49

query I
SELECT count(*) FROM glob('${OPENDAL_EXTERNAL_BASE}/*');
----
2
