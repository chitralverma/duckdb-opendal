# name: test/sql/common/layers.test
# description: Each OpenDAL layer attaches independently and a read still works
# group: [common]

#
# Isolates one layer at a time (retry / timeout / concurrent-limit / cache) via
# the global config surface, proving each attaches without breaking I/O. The
# all-at-once global surface is global_config.test; break paths are errors.test.
# Config is set before seeding because the memory backend gives each distinct
# effective config its own store.

require opendal

require parquet

require-env OPENDAL_BASE

# retry layer
statement ok
SET GLOBAL opendal_retry_config = MAP{'max_times':'3','jitter':'true','min_delay':'50ms','max_delay':'5s'};

statement ok
COPY (SELECT range AS id FROM range(200)) TO '${OPENDAL_BASE}/layers/retry.parquet' (FORMAT parquet);

query I
SELECT count(*) FROM read_parquet('${OPENDAL_BASE}/layers/retry.parquet');
----
200

statement ok
RESET opendal_retry_config;

# timeout layer
statement ok
SET GLOBAL opendal_timeout_config = MAP{'operation_timeout':'30s','io_timeout':'15s'};

statement ok
COPY (SELECT range AS id FROM range(200)) TO '${OPENDAL_BASE}/layers/timeout.parquet' (FORMAT parquet);

query I
SELECT count(*) FROM read_parquet('${OPENDAL_BASE}/layers/timeout.parquet');
----
200

statement ok
RESET opendal_timeout_config;

# concurrent-limit + I/O tuning layer
statement ok
SET GLOBAL opendal_io_config = MAP{'read.concurrent':'4','write.concurrent':'4','read.chunk_size':'256 KiB'};

statement ok
COPY (SELECT range AS id FROM range(200)) TO '${OPENDAL_BASE}/layers/io.parquet' (FORMAT parquet);

query I
SELECT count(*) FROM read_parquet('${OPENDAL_BASE}/layers/io.parquet');
----
200

statement ok
RESET opendal_io_config;

# cache layer
statement ok
SET GLOBAL opendal_cache_config = MAP{'memory_size':'16 MiB','shards':'2','min_file_size':'0'};

statement ok
COPY (SELECT range AS id FROM range(200)) TO '${OPENDAL_BASE}/layers/cache.parquet' (FORMAT parquet);

query I
SELECT count(*) FROM read_parquet('${OPENDAL_BASE}/layers/cache.parquet');
----
200

statement ok
RESET opendal_cache_config;
