# name: test/sql/common/secret_config.test
# description: Generic per-service secret registration, sections, SCOPE, rejection
# group: [common]

#
# Service-agnostic: exercises the secret framework itself, so it is safe under
# any --test-config. Secret names are unique to avoid clashing with the
# config's own init-script secret.

require opendal

require parquet

# Registration is driven by OpenDAL's runtime registry. Every compiled service
# gets the same generic config surface; disabled services get none.
statement ok
CREATE SECRET cfg_fs (
    TYPE fs, SCOPE 'fs://registry-only',
    config MAP{'root':'.'}, io_config MAP{'read.concurrent':'2'}
);

statement ok
CREATE SECRET cfg_memory (TYPE memory, SCOPE 'memory://registry-only', timeout_config MAP{'operation_timeout':'1s'});

# One generic service secret separates service, I/O, retry, timeout and cache
# options. Section presence applies that behavior; no `enable` key is needed.
statement ok
CREATE SECRET cfg_s3_generic (
    TYPE s3, SCOPE 's3://bucket-b',
    config MAP{'access_key_id':'k','secret_access_key':'s','enable_virtual_host_style':'false'},
    io_config MAP{'read.concurrent':'2','write.chunk_size':'8 MiB'},
    retry_config MAP{'max_times':'5','jitter':'true','min_delay':'100ms','max_delay':'10s'},
    timeout_config MAP{'operation_timeout':'1m','io_timeout':'15s'},
    cache_config MAP{'memory_size':'128 MiB','disk_path':'/tmp/odfs_cache','disk_size':'512 MiB'}
);

# The secret is visible and correctly typed/scoped.
query III
SELECT name, type, scope FROM duckdb_secrets() WHERE name = 'cfg_s3_generic';
----
cfg_s3_generic	s3	['s3://bucket-b']

# Sections remain distinct in secret storage.
query I
SELECT secret_string LIKE '%config.enable_virtual_host_style=false%'
   AND secret_string LIKE '%io.read.concurrent=2%'
   AND secret_string LIKE '%retry.max_times=5%'
   AND secret_string LIKE '%timeout.operation_timeout=1m%'
   AND secret_string LIKE '%cache.memory_size=128 MiB%'
FROM duckdb_secrets() WHERE name = 'cfg_s3_generic';
----
true

# Removed convenience and generic-layer parameters are rejected.
statement error
CREATE SECRET cfg_s3_old_convenience (TYPE s3, key_id 'k');
----
Unknown parameter

statement error
CREATE SECRET cfg_s3_old_layers (TYPE s3, layers MAP{'retry.max_times':'5'});
----
Unknown parameter

# Unknown parameters are rejected (strict allowlist — this is why we use the
# generic `config` MAP for arbitrary keys).
statement error
CREATE SECRET cfg_s3_bad (TYPE s3, SCOPE 's3://c', totally_unknown_param 'x');
----
Unknown parameter

# SCOPE matching resolves the right secret for a URL prefix.
query I
SELECT count(*) FROM which_secret('s3://bucket-b/data/x.parquet', 's3');
----
1
