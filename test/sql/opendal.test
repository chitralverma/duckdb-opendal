# name: test/sql/opendal.test
# description: test opendal extension (Phase 1 — FFI read path over fs://)
# group: [sql]

# Before we load the extension, this will fail
statement error
SELECT opendal_version();
----
Catalog Error: Scalar Function with name opendal_version does not exist!

# Require statement will ensure this test is run with this extension loaded
require opendal

# Parquet reader/writer used below.
require parquet

# Format: "opendal <ext-version> (built with opendal-core <lib-version>)". The
# ext version matches duckdb_extensions().extension_version; the opendal-core
# version is resolved from Cargo.toml at build time. Assert only the shape.
query I
SELECT opendal_version() ILIKE 'opendal % (built with opendal-core %)';
----
true

# The extension version embedded in opendal_version() equals the one DuckDB
# reports in duckdb_extensions().
query I
SELECT opendal_version() =
       'opendal ' || (SELECT extension_version FROM duckdb_extensions() WHERE extension_name = 'opendal')
       || ' (built with opendal-core ' || regexp_extract(opendal_version(), 'opendal-core (.*)\)', 1) || ')';
----
true

# Write a Parquet file with the native filesystem, then read it back through
# the OpenDAL fs:// scheme (Rust core, positioned/ranged reads).
statement ok
COPY (SELECT range AS id, range * 2 AS doubled, 'row_' || range AS label FROM range(1000))
TO '__TEST_DIR__/opendal_read.parquet' (FORMAT parquet);

query IIII
SELECT count(*), min(id), max(id), sum(doubled)
FROM read_parquet('fs://__TEST_DIR__/opendal_read.parquet');
----
1000	0	999	999000

# Projection + predicate pushdown exercises column-chunk ranged reads.
query II
SELECT id, label
FROM read_parquet('fs://__TEST_DIR__/opendal_read.parquet')
WHERE id BETWEEN 500 AND 502
ORDER BY id;
----
500	row_500
501	row_501
502	row_502

# CSV streaming path over fs://
statement ok
COPY (SELECT range AS id, 'v' || range AS v FROM range(500))
TO '__TEST_DIR__/opendal_read.csv' (FORMAT csv, HEADER);

query II
SELECT count(*), max(id) FROM read_csv('fs://__TEST_DIR__/opendal_read.csv');
----
500	499

# glob of a concrete existing path returns the one file
query I
SELECT count(*) FROM glob('fs://__TEST_DIR__/opendal_read.parquet');
----
1

# `file` is registered by OpenDAL's fs service and receives the same local-FS
# adapter behavior without appearing in a hand-maintained service catalog.
query I
SELECT count(*) FROM glob('file://__TEST_DIR__/opendal_read.parquet');
----
1

query I
SELECT count(*) FROM glob('FILE://__TEST_DIR__/opendal_read.parquet');
----
1

# Memory remains path-only: the first segment after :// is data path, not an
# authority. This guards scheme-agnostic parsing from dropping that segment.
statement ok
COPY (SELECT 42 AS id) TO 'memory://registry/path.parquet' (FORMAT parquet);

query I
SELECT id FROM read_parquet('memory://registry/path.parquet');
----
42

# ── Phase 2: listing / glob / table functions ───────────────────────────────

# Build a small tree using a Hive-partitioned write, which creates the
# subdirectories for us (native COPY does not create nested dirs on its own).
statement ok
COPY (SELECT range AS id, (range % 3) AS part FROM range(60))
TO '__TEST_DIR__/odtree' (FORMAT parquet, PARTITION_BY part, OVERWRITE_OR_IGNORE);

# Recursive glob across all partitions: 60 rows total.
query I
SELECT count(*) FROM read_parquet('fs://__TEST_DIR__/odtree/**/*.parquet');
----
60

# Recursive glob restricted to one partition value.
query I
SELECT count(*) FROM read_parquet('fs://__TEST_DIR__/odtree/part=0/*.parquet');
----
20

# opendal_ls (non-recursive) on the tree lists the partition directories.
query I
SELECT count(*) FROM opendal_ls('fs://__TEST_DIR__/odtree/') WHERE metadata.mode = 'directory';
----
3

# opendal_ls (recursive) sees the leaf parquet files (one per partition).
query I
SELECT count(*) FROM opendal_ls('fs://__TEST_DIR__/odtree/', recursive := true) WHERE metadata.mode = 'file';
----
3

# opendal_stat returns exactly one row for a concrete file.
query I
SELECT count(*) FROM opendal_stat('fs://__TEST_DIR__/opendal_read.parquet');
----
1

query II
SELECT name, metadata.content_length > 0
FROM opendal_stat('fs://__TEST_DIR__/opendal_read.parquet');
----
opendal_read.parquet	true

# OpenDAL list options are typed named arguments; backend order is intentionally
# preserved, so tests sort only when order matters.
query I
SELECT count(*) FROM opendal_ls('fs://__TEST_DIR__/odtree/', recursive := true, "limit" := 1);
----
6

query I
SELECT count(*) FROM opendal_glob('fs://__TEST_DIR__/odtree/**/*.parquet')
WHERE metadata.mode = 'file';
----
3

# opendal_du rolls up sizes recursively across the partitions (3 groups, 60 files? no —
# one file per partition dir, so 3 groups each with 1 file).
query I
SELECT count(*) FROM opendal_du('fs://__TEST_DIR__/odtree/');
----
3

query I
SELECT sum(file_count) FROM opendal_du('fs://__TEST_DIR__/odtree/');
----
3

# Files and globs use the same Rust target resolver and retain parent grouping.
query II
SELECT file_count, total_size > 0
FROM opendal_du('fs://__TEST_DIR__/opendal_read.parquet');
----
1	true

query I
SELECT sum(file_count) FROM opendal_du('fs://__TEST_DIR__/odtree/**/*.parquet');
----
3

# Same-operator copy uses OpenDAL Copier where supported and falls back to a
# Reader->Writer transfer otherwise. Success emits one row after commit.
query II
SELECT bytes_copied > 0, metadata.mode
FROM opendal_copy(
    'fs://__TEST_DIR__/opendal_read.parquet',
    'fs://__TEST_DIR__/opendal_copy.parquet'
);
----
true	file

query I
SELECT count(*) FROM read_parquet('fs://__TEST_DIR__/opendal_copy.parquet');
----
1000

statement error
SELECT * FROM opendal_copy(
    'fs://__TEST_DIR__/opendal_read.parquet',
    'fs://__TEST_DIR__/opendal_copy.parquet',
    if_not_exists := true
);
----
exist

# Mutation happens in the scan callback, not bind/init. LIMIT 0 must not copy.
statement ok
SELECT count(*) FROM opendal_copy(
    'fs://__TEST_DIR__/opendal_read.parquet',
    'fs://__TEST_DIR__/opendal_not_copied.parquet'
) LIMIT 0;

query I
SELECT count(*) FROM opendal_glob('fs://__TEST_DIR__/opendal_not_copied*.parquet');
----
0

# Content length is a validated planning hint and must never truncate transfer.
statement error
SELECT * FROM opendal_copy(
    'fs://__TEST_DIR__/opendal_read.parquet',
    'fs://__TEST_DIR__/opendal_hint_copy.parquet',
    source_content_length_hint := 1
);
----
does not match source size

query I
SELECT count(*) FROM opendal_glob('fs://__TEST_DIR__/opendal_hint_copy*.parquet');
----
0

# ── DuckDB's built-in glob() table function routes through opendal ─────────

# Exact path.
query I
SELECT count(*) FROM glob('fs://__TEST_DIR__/opendal_read.parquet');
----
1

# Wildcard across the partitioned tree (one leaf file per partition dir).
query I
SELECT count(*) FROM glob('fs://__TEST_DIR__/odtree/**/*.parquet');
----
3

# glob() of a non-existent directory returns no rows (clean, no error).
query I
SELECT count(*) FROM glob('fs://__TEST_DIR__/does_not_exist_xyz/*.parquet');
----
0

# Directories are not returned by glob (matches native glob semantics): a bare
# '*' over the tree root matches only the partition directories' contents, not
# the directories themselves — so globbing '*' at the CSV/parquet root yields
# only files.
query I
SELECT count(*) FROM glob('fs://__TEST_DIR__/opendal_read.*');
----
2

# ── Phase 4: write path (COPY TO fs://) ─────────────────────────────────────

# COPY TO fs:// writes a Parquet file through the streaming writer; round-trip.
statement ok
COPY (SELECT range AS id, range * range AS sq FROM range(1000))
TO 'fs://__TEST_DIR__/w_out.parquet' (FORMAT parquet);

query II
SELECT count(*), sum(sq) FROM read_parquet('fs://__TEST_DIR__/w_out.parquet');
----
1000	332833500

# The written file is a valid on-disk Parquet (native read agrees).
query I
SELECT count(*) FROM read_parquet('__TEST_DIR__/w_out.parquet');
----
1000

# CSV write + round-trip.
statement ok
COPY (SELECT range AS id, 'v' || range AS v FROM range(250))
TO 'fs://__TEST_DIR__/w_out.csv' (FORMAT csv, HEADER);

query II
SELECT count(*), max(id) FROM read_csv('fs://__TEST_DIR__/w_out.csv');
----
250	249

# Writing into a not-yet-existing nested directory works (OpenDAL creates the
# parent path; native COPY would fail here).
statement ok
COPY (SELECT range AS id FROM range(10))
TO 'fs://__TEST_DIR__/w_new/deep/f.parquet' (FORMAT parquet);

query I
SELECT count(*) FROM read_parquet('fs://__TEST_DIR__/w_new/deep/f.parquet');
----
10

# Overwrite replaces the object's contents.
statement ok
COPY (SELECT 1 AS x) TO 'fs://__TEST_DIR__/w_ow.parquet' (FORMAT parquet);

statement ok
COPY (SELECT range AS x FROM range(5)) TO 'fs://__TEST_DIR__/w_ow.parquet' (FORMAT parquet);

query I
SELECT count(*) FROM read_parquet('fs://__TEST_DIR__/w_ow.parquet');
----
5

# Partitioned write creates the partition directories and one file per value.
statement ok
COPY (SELECT range AS id, range % 4 AS part FROM range(400))
TO 'fs://__TEST_DIR__/w_parts' (FORMAT parquet, PARTITION_BY part, OVERWRITE_OR_IGNORE);

query II
SELECT part, count(*) FROM read_parquet('fs://__TEST_DIR__/w_parts/**/*.parquet', hive_partitioning = true)
GROUP BY part ORDER BY part;
----
0	100
1	100
2	100
3	100

# ── Phase 3: secret registration (no live backend needed) ───────────────────

# Secret registration is driven by OpenDAL's runtime registry. Every compiled
# service gets the same generic config surface; disabled services get none.
statement ok
CREATE SECRET fs_registry (TYPE fs, SCOPE 'fs://', io_config MAP{'read.concurrent':'2'});

statement ok
CREATE SECRET memory_registry (TYPE memory, SCOPE 'memory://', timeout_config MAP{'operation_timeout':'1s'});

# DuckDB maps unknown GCS secret types to httpfs. Disable known-extension
# autoload explicitly so this assertion tests our compiled registry without
# partially loading httpfs after opendal (that load order collides on TYPE s3).
statement ok
SET autoload_known_extensions = false;

statement error
CREATE SECRET gcs_not_compiled (TYPE gcs, config MAP{});
----
Secret type 'gcs' does not exist

# One generic service secret separates backend, I/O, retry, timeout and cache
# options. Section presence applies that behavior; no `enable` key is needed.
statement ok
CREATE SECRET s3_generic (
    TYPE s3, SCOPE 's3://bucket-b',
    config MAP{'access_key_id':'k','secret_access_key':'s','enable_virtual_host_style':'false'},
    io_config MAP{'read.concurrent':'2','write.chunk_size':'8 MiB'},
    retry_config MAP{'max_times':'5','jitter':'true','min_delay':'100ms','max_delay':'10s'},
    timeout_config MAP{'operation_timeout':'1m','io_timeout':'15s'},
    cache_config MAP{'memory_size':'128 MiB','disk_path':'/tmp/odfs_cache','disk_size':'512 MiB'}
);

# The secret is visible and correctly typed/scoped.
query III
SELECT name, type, scope FROM duckdb_secrets() WHERE name LIKE 's3_%' ORDER BY name;
----
s3_generic	s3	['s3://bucket-b']

# Sections remain distinct in secret storage.
query I
SELECT secret_string LIKE '%config.enable_virtual_host_style=false%'
   AND secret_string LIKE '%io.read.concurrent=2%'
   AND secret_string LIKE '%retry.max_times=5%'
   AND secret_string LIKE '%timeout.operation_timeout=1m%'
   AND secret_string LIKE '%cache.memory_size=128 MiB%'
FROM duckdb_secrets() WHERE name = 's3_generic';
----
true

# Removed convenience and generic-layer parameters are rejected.
statement error
CREATE SECRET s3_old_convenience (TYPE s3, key_id 'k');
----
Unknown parameter

statement error
CREATE SECRET s3_old_layers (TYPE s3, layers MAP{'retry.max_times':'5'});
----
Unknown parameter

# Global sections use the same names as secret sections and apply to every
# service/path. A missing section means no layer/cache is applied.
statement ok
SET GLOBAL opendal_io_config = MAP{'read.concurrent':'2','read.chunk_size':'256 KiB'};

statement ok
SET GLOBAL opendal_retry_config = MAP{'max_times':'4'};

statement ok
SET GLOBAL opendal_timeout_config = MAP{'operation_timeout':'30s'};

# Global cache applies to fs:// too; section presence enables it.
statement ok
SET GLOBAL opendal_cache_config = MAP{'memory_size':'16 MiB','shards':'2','min_file_size':'0'};

query I
SELECT count(*) FROM read_parquet('fs://__TEST_DIR__/w_out.parquet');
----
1000

statement ok
RESET opendal_io_config;

statement ok
RESET opendal_retry_config;

statement ok
RESET opendal_timeout_config;

statement ok
RESET opendal_cache_config;

# Best-effort cache build failures are DuckDB warnings, not stderr output. Use
# an existing file as disk_path so cache directory creation fails predictably;
# the filesystem operation still succeeds without cache.
statement ok
CALL enable_logging(level='warning', storage='memory');

statement ok
SET GLOBAL opendal_cache_config = MAP{'memory_size':'16 MB','disk_path':'__TEST_DIR__/w_out.parquet'};

query I
SELECT count(*) FROM opendal_stat('fs://__TEST_DIR__/w_out.parquet');
----
1

query I
SELECT count(*) FROM duckdb_logs()
WHERE log_level = 'WARNING' AND message LIKE 'OpenDAL cache disabled:%';
----
1

statement ok
RESET opendal_cache_config;

statement ok
CALL disable_logging();

# Invalid cross-service values are rejected when the effective operator is
# built; they are never silently dropped to defaults.
statement ok
SET GLOBAL opendal_retry_config = MAP{'max_times':'banana'};

statement error
SELECT * FROM opendal_stat('fs://__TEST_DIR__/w_out.parquet');
----
invalid retry.max_times='banana'

# FileExists/Glob must propagate the same operator error rather than converting
# it into "No files found" or an empty wildcard result.
statement error
SELECT count(*) FROM read_parquet('fs://__TEST_DIR__/w_out.parquet');
----
invalid retry.max_times='banana'

statement error
SELECT count(*) FROM glob('fs://__TEST_DIR__/*.parquet');
----
invalid retry.max_times='banana'

statement ok
RESET opendal_retry_config;

statement ok
SET GLOBAL opendal_cache_config = MAP{'shradz':'4'};

statement error
SELECT * FROM opendal_stat('fs://__TEST_DIR__/w_out.parquet');
----
unknown OpenDAL option 'cache.shradz'

statement ok
RESET opendal_cache_config;

# Typed service values are validated by OpenDAL and propagated as input errors.
statement ok
CREATE SECRET s3_invalid_config (
    TYPE s3, SCOPE 's3://invalid-config-bucket',
    config MAP{'enable_virtual_host_style':'banana'}
);

statement error
SELECT * FROM opendal_stat('s3://invalid-config-bucket/file');
----
failed to deserialize config

# ── Native-filesystem override setting (Phase 5 hardening) ───────────────────

# The setting exists and defaults to empty (no override).
query I
SELECT current_setting('opendal_override_native_filesystems') = '';
----
true

query I
SELECT opendal_is_manually_set('s3://bucket/file');
----
false

# Unsupported/non-OpenDAL paths never report manual dispatch.
query I
SELECT opendal_is_manually_set('https://example.com/file');
----
false

# It accepts a comma-separated scheme list.
statement ok
SET opendal_override_native_filesystems = 's3,gcs';

query I
SELECT current_setting('opendal_override_native_filesystems');
----
s3,gcs

# Locks DuckDB's same-thread CanHandleFile -> IsManuallySet coupling.
query II
SELECT opendal_is_manually_set('s3://bucket/file'),
       opendal_is_manually_set('fs://__TEST_DIR__/w_out.parquet');
----
true	false

# Reads through opendal still work with the override set.
query I
SELECT count(*) FROM read_parquet('fs://__TEST_DIR__/w_out.parquet');
----
1000

# Reset the override.
statement ok
SET opendal_override_native_filesystems = '';

query I
SELECT opendal_is_manually_set('s3://bucket/file');
----
false

# SCOPE matching resolves the right secret for a URL prefix.
query I
SELECT count(*) FROM which_secret('s3://bucket-b/data/x.parquet', 's3');
----
1

# Unknown parameters are rejected (strict allowlist — this is why we use the
# generic `config` MAP for arbitrary keys).
statement error
CREATE SECRET s3_bad (TYPE s3, SCOPE 's3://c', totally_unknown_param 'x');
----
Unknown parameter

# ── DuckDB FileSystem logging integration ───────────────────────────────────
# Our reads/writes emit DuckDB's native structured FileSystem log entries
# (fs/path/op/bytes/pos), queryable via duckdb_logs_parsed('FileSystem').
statement ok
CALL enable_logging(level='trace', storage='memory');

statement ok
COPY (SELECT range AS id FROM range(200)) TO 'fs://__TEST_DIR__/logtest.parquet' (FORMAT parquet);

statement ok
SELECT count(*) FROM read_parquet('fs://__TEST_DIR__/logtest.parquet');

# We logged at least one OPEN, READ, WRITE and CLOSE against our filesystem.
query I
SELECT count(DISTINCT op) FROM duckdb_logs_parsed('FileSystem')
WHERE fs = 'OpenDalFileSystem' AND op IN ('OPEN','READ','WRITE','CLOSE');
----
4

statement ok
CALL disable_logging();
