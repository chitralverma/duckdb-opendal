# name: test/sql/opendal.test
# description: test opendal extension (Phase 1 — FFI read path over fs://)
# group: [sql]

# Before we load the extension, this will fail
statement error
SELECT opendal_version();
----
Catalog Error: Scalar Function with name opendal_version does not exist!

# Require statement will ensure this test is run with this extension loaded
require opendal

# Parquet reader/writer used below.
require parquet

# The version string comes from the Rust core (duckdb-opendal) across the FFI.
# The OpenDAL version is resolved from Cargo.lock at build time (not hardcoded),
# so assert only the shape, not a specific version.
query I
SELECT opendal_version() ILIKE 'duckdb-opendal%(opendal %)%';
----
true

# Write a Parquet file with the native filesystem, then read it back through
# the OpenDAL fs:// scheme (Rust core, positioned/ranged reads).
statement ok
COPY (SELECT range AS id, range * 2 AS doubled, 'row_' || range AS label FROM range(1000))
TO '__TEST_DIR__/opendal_fs_read.parquet' (FORMAT parquet);

query IIII
SELECT count(*), min(id), max(id), sum(doubled)
FROM read_parquet('fs://__TEST_DIR__/opendal_fs_read.parquet');
----
1000	0	999	999000

# Projection + predicate pushdown exercises column-chunk ranged reads.
query II
SELECT id, label
FROM read_parquet('fs://__TEST_DIR__/opendal_fs_read.parquet')
WHERE id BETWEEN 500 AND 502
ORDER BY id;
----
500	row_500
501	row_501
502	row_502

# CSV streaming path over fs://
statement ok
COPY (SELECT range AS id, 'v' || range AS v FROM range(500))
TO '__TEST_DIR__/opendal_fs_read.csv' (FORMAT csv, HEADER);

query II
SELECT count(*), max(id) FROM read_csv('fs://__TEST_DIR__/opendal_fs_read.csv');
----
500	499

# glob of a concrete existing path returns the one file
query I
SELECT count(*) FROM glob('fs://__TEST_DIR__/opendal_fs_read.parquet');
----
1

# ── Phase 2: listing / glob / table functions ───────────────────────────────

# Build a small tree using a Hive-partitioned write, which creates the
# subdirectories for us (native COPY does not create nested dirs on its own).
statement ok
COPY (SELECT range AS id, (range % 3) AS part FROM range(60))
TO '__TEST_DIR__/odtree' (FORMAT parquet, PARTITION_BY part, OVERWRITE_OR_IGNORE);

# Recursive glob across all partitions: 60 rows total.
query I
SELECT count(*) FROM read_parquet('fs://__TEST_DIR__/odtree/**/*.parquet');
----
60

# Recursive glob restricted to one partition value.
query I
SELECT count(*) FROM read_parquet('fs://__TEST_DIR__/odtree/part=0/*.parquet');
----
20

# opendal_ls (non-recursive) on the tree lists the partition directories.
query I
SELECT count(*) FROM opendal_ls('fs://__TEST_DIR__/odtree/') WHERE type = 'directory';
----
3

# opendal_ls (recursive) sees the leaf parquet files (one per partition).
query I
SELECT count(*) FROM opendal_ls('fs://__TEST_DIR__/odtree/', recursive := true) WHERE type = 'file';
----
3

# opendal_stat returns exactly one row for a concrete file.
query I
SELECT count(*) FROM opendal_stat('fs://__TEST_DIR__/opendal_fs_read.parquet');
----
1

# opendal_du rolls up sizes recursively across the partitions (3 groups, 60 files? no —
# one file per partition dir, so 3 groups each with 1 file).
query I
SELECT count(*) FROM opendal_du('fs://__TEST_DIR__/odtree/');
----
3

query I
SELECT sum(file_count) FROM opendal_du('fs://__TEST_DIR__/odtree/');
----
3

# ── DuckDB's built-in glob() table function routes through opendalfs ─────────

# Exact path.
query I
SELECT count(*) FROM glob('fs://__TEST_DIR__/opendal_fs_read.parquet');
----
1

# Wildcard across the partitioned tree (one leaf file per partition dir).
query I
SELECT count(*) FROM glob('fs://__TEST_DIR__/odtree/**/*.parquet');
----
3

# glob() of a non-existent directory returns no rows (clean, no error).
query I
SELECT count(*) FROM glob('fs://__TEST_DIR__/does_not_exist_xyz/*.parquet');
----
0

# Directories are not returned by glob (matches native glob semantics): a bare
# '*' over the tree root matches only the partition directories' contents, not
# the directories themselves — so globbing '*' at the CSV/parquet root yields
# only files.
query I
SELECT count(*) FROM glob('fs://__TEST_DIR__/opendal_fs_read.*');
----
2

# ── Phase 4: write path (COPY TO fs://) ─────────────────────────────────────

# COPY TO fs:// writes a Parquet file through the streaming writer; round-trip.
statement ok
COPY (SELECT range AS id, range * range AS sq FROM range(1000))
TO 'fs://__TEST_DIR__/w_out.parquet' (FORMAT parquet);

query II
SELECT count(*), sum(sq) FROM read_parquet('fs://__TEST_DIR__/w_out.parquet');
----
1000	332833500

# The written file is a valid on-disk Parquet (native read agrees).
query I
SELECT count(*) FROM read_parquet('__TEST_DIR__/w_out.parquet');
----
1000

# CSV write + round-trip.
statement ok
COPY (SELECT range AS id, 'v' || range AS v FROM range(250))
TO 'fs://__TEST_DIR__/w_out.csv' (FORMAT csv, HEADER);

query II
SELECT count(*), max(id) FROM read_csv('fs://__TEST_DIR__/w_out.csv');
----
250	249

# Writing into a not-yet-existing nested directory works (OpenDAL creates the
# parent path; native COPY would fail here).
statement ok
COPY (SELECT range AS id FROM range(10))
TO 'fs://__TEST_DIR__/w_new/deep/f.parquet' (FORMAT parquet);

query I
SELECT count(*) FROM read_parquet('fs://__TEST_DIR__/w_new/deep/f.parquet');
----
10

# Overwrite replaces the object's contents.
statement ok
COPY (SELECT 1 AS x) TO 'fs://__TEST_DIR__/w_ow.parquet' (FORMAT parquet);

statement ok
COPY (SELECT range AS x FROM range(5)) TO 'fs://__TEST_DIR__/w_ow.parquet' (FORMAT parquet);

query I
SELECT count(*) FROM read_parquet('fs://__TEST_DIR__/w_ow.parquet');
----
5

# Partitioned write creates the partition directories and one file per value.
statement ok
COPY (SELECT range AS id, range % 4 AS part FROM range(400))
TO 'fs://__TEST_DIR__/w_parts' (FORMAT parquet, PARTITION_BY part, OVERWRITE_OR_IGNORE);

query II
SELECT part, count(*) FROM read_parquet('fs://__TEST_DIR__/w_parts/**/*.parquet', hive_partitioning = true)
GROUP BY part ORDER BY part;
----
0	100
1	100
2	100
3	100

# ── Phase 3: secret registration (no live backend needed) ───────────────────

# A per-service secret type is registered (TYPE s3) with SCOPE + config.
statement ok
CREATE SECRET s3_convenience (
    TYPE s3, SCOPE 's3://bucket-a',
    key_id 'AKIA', secret 'shhh', region 'us-west-2', endpoint 'http://localhost:9000'
);

# The generic `config` MAP accepts arbitrary OpenDAL keys (no per-key allowlist).
statement ok
CREATE SECRET s3_generic (
    TYPE s3, SCOPE 's3://bucket-b',
    config MAP{'access_key_id':'k','secret_access_key':'s','enable_virtual_host_style':'false'},
    layers MAP{'retry.max_times':'5','timeout.seconds':'60'}
);

# Both secrets are visible and correctly typed/scoped.
query III
SELECT name, type, scope FROM duckdb_secrets() WHERE name LIKE 's3_%' ORDER BY name;
----
s3_convenience	s3	['s3://bucket-a']
s3_generic	s3	['s3://bucket-b']

# The convenience params were normalized to OpenDAL config keys in the secret.
query I
SELECT secret_string LIKE '%access_key_id=AKIA%' AND secret_string LIKE '%secret_access_key=shhh%'
FROM duckdb_secrets() WHERE name = 's3_convenience';
----
true

# The generic config keys and layer options are stored (layers under layer.*).
query I
SELECT secret_string LIKE '%enable_virtual_host_style=false%'
   AND secret_string LIKE '%layer.retry.max_times=5%'
FROM duckdb_secrets() WHERE name = 's3_generic';
----
true

# Foyer cache options are accepted and stored as layer.* entries (Phase 5).
statement ok
CREATE SECRET s3_foyer (
    TYPE s3, SCOPE 's3://bucket-cache',
    key_id 'k', secret 's',
    layers MAP{'foyer.enable':'true','foyer.memory_mb':'128'}
);

query I
SELECT secret_string LIKE '%layer.foyer.enable=true%'
   AND secret_string LIKE '%layer.foyer.memory_mb=128%'
FROM duckdb_secrets() WHERE name = 's3_foyer';
----
true

# Foyer on-disk cache options are accepted and stored (Phase 5 hardening).
statement ok
CREATE SECRET s3_foyer_disk (
    TYPE s3, SCOPE 's3://bucket-disk',
    key_id 'k', secret 's',
    layers MAP{'foyer.enable':'true','foyer.disk_path':'/tmp/odfs_cache','foyer.disk_mb':'512'}
);

query I
SELECT secret_string LIKE '%layer.foyer.disk_path=/tmp/odfs_cache%'
   AND secret_string LIKE '%layer.foyer.disk_mb=512%'
FROM duckdb_secrets() WHERE name = 's3_foyer_disk';
----
true

# ── Native-filesystem override setting (Phase 5 hardening) ───────────────────

# The setting exists and defaults to empty (no override).
query I
SELECT current_setting('opendal_override_native_filesystems') = '';
----
true

# It accepts a comma-separated scheme list.
statement ok
SET opendal_override_native_filesystems = 's3,gcs';

query I
SELECT current_setting('opendal_override_native_filesystems');
----
s3,gcs

# Reads through opendal_fs still work with the override set.
query I
SELECT count(*) FROM read_parquet('fs://__TEST_DIR__/w_out.parquet');
----
1000

# Reset the override.
statement ok
SET opendal_override_native_filesystems = '';

# SCOPE matching resolves the right secret for a URL prefix.
query I
SELECT count(*) FROM which_secret('s3://bucket-a/data/x.parquet', 's3');
----
1

# Unknown parameters are rejected (strict allowlist — this is why we use the
# generic `config` MAP for arbitrary keys).
statement error
CREATE SECRET s3_bad (TYPE s3, SCOPE 's3://c', totally_unknown_param 'x');
----
Unknown parameter

# ── DuckDB FileSystem logging integration ───────────────────────────────────
# Our reads/writes emit DuckDB's native structured FileSystem log entries
# (fs/path/op/bytes/pos), queryable via duckdb_logs_parsed('FileSystem').
statement ok
CALL enable_logging(level='trace', storage='memory');

statement ok
COPY (SELECT range AS id FROM range(200)) TO 'fs://__TEST_DIR__/logtest.parquet' (FORMAT parquet);

statement ok
SELECT count(*) FROM read_parquet('fs://__TEST_DIR__/logtest.parquet');

# We logged at least one OPEN, READ, WRITE and CLOSE against our filesystem.
query I
SELECT count(DISTINCT op) FROM duckdb_logs_parsed('FileSystem')
WHERE fs = 'OpenDalFileSystem' AND op IN ('OPEN','READ','WRITE','CLOSE');
----
4

statement ok
CALL disable_logging();
