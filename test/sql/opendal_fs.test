# name: test/sql/opendal_fs.test
# description: test opendal_fs extension (Phase 0 — FFI link smoke test)
# group: [sql]

# Before we load the extension, this will fail
statement error
SELECT opendal_fs_version();
----
Catalog Error: Scalar Function with name opendal_fs_version does not exist!

# Require statement will ensure this test is run with this extension loaded
require opendal_fs

# The version string comes from the Rust core (opendalfs-core) across the FFI.
query I
SELECT opendal_fs_version() ILIKE 'opendalfs-core%opendal 0.57%';
----
true
