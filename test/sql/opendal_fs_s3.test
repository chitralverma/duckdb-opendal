# name: test/sql/opendal_fs_s3.test
# description: opendalfs over S3 (MinIO) — opt-in; requires a seeded MinIO
# group: [sql]
#
# This test is skipped unless OPENDAL_S3_TEST is set. To run it locally:
#   scripts/s3_test_seed.sh up      # start + seed MinIO, prints env to export
#   <export the printed env vars>
#   make test                       # or run this file directly via unittest
#   scripts/s3_test_seed.sh down    # teardown
#
# Credentials/endpoint are read by the OpenDAL S3 service from the AWS_* env
# vars (Phase 3 will replace these with CREATE SECRET). The fixtures live in the
# `warehouse` bucket seeded by scripts/s3_test_seed.sh.

require opendal_fs

require parquet

require-env OPENDAL_S3_TEST

# Single object read.
query II
SELECT count(*), sum(d) FROM read_parquet('s3://warehouse/f1.parquet');
----
100	9900

# Wildcard glob read at the bucket root (f1 + f2).
query I
SELECT count(*) FROM read_parquet('s3://warehouse/*.parquet');
----
300

# Recursive glob read (adds the partitioned nested.parquet).
query I
SELECT count(*) FROM read_parquet('s3://warehouse/**/*.parquet');
----
350

# DuckDB's built-in glob() over S3.
query I
SELECT count(*) FROM glob('s3://warehouse/*.parquet');
----
2

# Recursive glob() over S3.
query I
SELECT count(*) FROM glob('s3://warehouse/**/*.parquet');
----
3

# CSV over S3.
query II
SELECT count(*), max(id) FROM read_csv('s3://warehouse/data.csv');
----
75	74

# Projection + predicate pushdown (ranged column reads).
query II
SELECT id, d FROM read_parquet('s3://warehouse/f2.parquet') WHERE id BETWEEN 100 AND 102 ORDER BY id;
----
100	300
101	303
102	306

# Join across two S3 objects.
query I
SELECT count(*) FROM read_parquet('s3://warehouse/f1.parquet') a
JOIN read_parquet('s3://warehouse/f2.parquet') b USING (id);
----
100

# Hive partitioning: the year= value is extracted from the object key.
query II
SELECT any_value(id) >= 0 AS has_id, any_value(year) AS y
FROM read_parquet('s3://warehouse/year=2024/nested.parquet', hive_partitioning = true);
----
true	2024

# opendal_ls (recursive) over the bucket lists all objects.
query I
SELECT count(*) FROM opendal_ls('s3://warehouse/', recursive := true) WHERE type = 'file';
----
4

# opendal_du rolls up per prefix: the root group plus the year=2024 prefix.
query I
SELECT count(*) FROM opendal_du('s3://warehouse/');
----
2

# opendal_stat on a single S3 object returns exactly one row.
query I
SELECT count(*) FROM opendal_stat('s3://warehouse/f1.parquet');
----
1

# ── Secret-backed access (SCOPE-matched CREATE SECRET) ──────────────────────
# These mirror the reads above but drive the S3 config from CREATE SECRET rather
# than the environment. Two distinct scoped secrets prove SCOPE resolution.

statement ok
CREATE SECRET s3_warehouse (
    TYPE s3, SCOPE 's3://warehouse',
    key_id 'minioadmin', secret 'minioadmin',
    region 'us-east-1', endpoint 'http://127.0.0.1:19100'
);

statement ok
CREATE SECRET s3_vault (
    TYPE s3, SCOPE 's3://vault',
    key_id 'minioadmin', secret 'minioadmin',
    region 'us-east-1', endpoint 'http://127.0.0.1:19100',
    layers MAP{'retry.max_times':'3','timeout.seconds':'30'}
);

# The warehouse-scoped secret drives this read.
query I
SELECT count(*) FROM read_parquet('s3://warehouse/f1.parquet');
----
100

# The vault-scoped secret (with layers) drives this read.
query I
SELECT count(*) FROM read_parquet('s3://vault/only.parquet');
----
42

# Both buckets in one query — each URL resolves to its own scoped secret.
query II rowsort
SELECT 'warehouse' AS bucket, count(*) AS n FROM read_parquet('s3://warehouse/f1.parquet')
UNION ALL
SELECT 'vault', count(*) FROM read_parquet('s3://vault/only.parquet');
----
vault	42
warehouse	100

# ── Write path over S3 (COPY TO) ────────────────────────────────────────────

# COPY TO an S3 object via the streaming writer, then read it back.
statement ok
COPY (SELECT range AS id, range * 10 AS v FROM range(333))
TO 's3://warehouse/written/out.parquet' (FORMAT parquet);

query II
SELECT count(*), sum(v) FROM read_parquet('s3://warehouse/written/out.parquet');
----
333	552780

# I/O tuning: global concurrent + chunk on the multipart write path. The write
# must still round-trip correctly with tuning enabled.
statement ok
SET opendal_write_concurrent=4;

statement ok
SET opendal_write_chunk=8388608;

statement ok
SET opendal_read_concurrent=2;

statement ok
COPY (SELECT range AS id, range * 2 AS v FROM range(500))
TO 's3://warehouse/tuned/out.parquet' (FORMAT parquet);

query II
SELECT count(*), sum(v) FROM read_parquet('s3://warehouse/tuned/out.parquet');
----
500	249500

# Reset globals so later cases use service defaults.
statement ok
SET opendal_write_concurrent=0;

statement ok
SET opendal_write_chunk=0;

statement ok
SET opendal_read_concurrent=0;

# Per-secret I/O tuning via the layers map (io.* keys) — scoped to one bucket.
statement ok
CREATE SECRET s3_tuned (
    TYPE s3, SCOPE 's3://warehouse/perssecret',
    key_id 'minioadmin', secret 'minioadmin', region 'us-east-1',
    endpoint 'http://127.0.0.1:19100',
    config MAP{'enable_virtual_host_style':'false'},
    layers MAP{'io.write.concurrent':'4','io.write.chunk':'8388608'}
);

statement ok
COPY (SELECT range AS id FROM range(250))
TO 's3://warehouse/perssecret/out.parquet' (FORMAT parquet);

query I
SELECT count(*) FROM read_parquet('s3://warehouse/perssecret/out.parquet');
----
250

# Partitioned write to S3 creates one object per partition value.
statement ok
COPY (SELECT range AS id, range % 3 AS p FROM range(300))
TO 's3://warehouse/pw' (FORMAT parquet, PARTITION_BY p, OVERWRITE_OR_IGNORE);

query II
SELECT p, count(*) FROM read_parquet('s3://warehouse/pw/**/*.parquet', hive_partitioning = true)
GROUP BY p ORDER BY p;
----
0	100
1	100
2	100

# ── Foyer cache layer over S3 (Phase 5) ─────────────────────────────────────
# Read through a foyer-enabled operator. We use the `vault` bucket with a
# foyer-enabled secret; because operators are cached per scheme://authority for
# the lifetime of the process, this secret must be created before the first
# vault read for the layer to take effect. (The earlier vault reads used the
# non-foyer s3_vault secret, so here we target a distinct object under vault via
# a longer-scoped, foyer-enabled secret that wins the match.)
statement ok
CREATE SECRET s3_foyer_vault (
    TYPE s3, SCOPE 's3://vault/only.parquet',
    key_id 'minioadmin', secret 'minioadmin',
    region 'us-east-1', endpoint 'http://127.0.0.1:19100',
    layers MAP{'foyer.enable':'true','foyer.memory_mb':'64'}
);

# The foyer-enabled read works (cache is transparent). Note: the operator for
# s3://vault may already be cached from earlier reads; correctness (not cache
# residency) is what this asserts.
query I
SELECT count(*) FROM read_parquet('s3://vault/only.parquet');
----
42

# On-disk foyer cache configured via a secret also drives a working read. We
# write a fresh object under warehouse and read it back through the foyer-disk
# operator (the s3://warehouse operator is cached from earlier reads, so this
# asserts correctness rather than disk residency; disk residency is covered by
# the Rust unit test).
statement ok
CREATE SECRET s3_foyer_disk_wh (
    TYPE s3, SCOPE 's3://warehouse/foyerdisk',
    key_id 'minioadmin', secret 'minioadmin',
    region 'us-east-1', endpoint 'http://127.0.0.1:19100',
    layers MAP{'foyer.enable':'true','foyer.disk_path':'__TEST_DIR__/foyer_s3_cache','foyer.disk_mb':'64','foyer.block_mb':'1'}
);

statement ok
COPY (SELECT range AS id FROM range(123)) TO 's3://warehouse/foyerdisk/f.parquet' (FORMAT parquet);

query I
SELECT count(*) FROM read_parquet('s3://warehouse/foyerdisk/f.parquet');
----
123
