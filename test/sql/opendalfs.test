# name: test/sql/opendalfs.test
# description: test opendalfs extension
# group: [sql]

# Before we load the extension, this will fail
statement error
SELECT opendalfs('Sam');
----
Catalog Error: Scalar Function with name opendalfs does not exist!

# Require statement will ensure this test is run with this extension loaded
require opendalfs

# Confirm the extension works
query I
SELECT opendalfs('Sam');
----
Opendalfs Sam 🐥

query I
SELECT opendalfs_openssl_version('Michael') ILIKE 'Opendalfs Michael, my linked OpenSSL version is OpenSSL%';
----
true
